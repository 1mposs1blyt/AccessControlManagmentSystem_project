{
  "name": "solito-blank",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@tamagui/babel-plugin": "^2.0.0-rc.41",
    "@tamagui/next-plugin": "^2.0.0-rc.41",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.73.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.21.0",
    "prisma": "^7.7.0",
    "turbo": "^2.4.4",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "native": "cd apps/expo && yarn start",
    "web": "cd apps/next && yarn next",
    "db-s": "cd packages/db && yarn studio",
    "db-g": "cd packages/db && yarn generate",
    "db-m": "cd packages/db && yarn migrate",
    "db-ldb": "cd packages/db && yarn localdb"
  },
  "eslintConfig": {
    "extends": "next",
    "settings": {
      "next": {
        "rootDir": "apps/next/"
      }
    },
    "root": true
  },
  "prettier": {
    "semi": false,
    "useTabs": false,
    "tabWidth": 2,
    "singleQuote": true
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-menu/menu": "^2.0.0",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/lucide-icons": "2.0.0-rc.26",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "babel-preset-expo": "^55.0.17",
    "bcrypt": "^6.0.0",
    "expo-linking": "^55.0.13",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-svg": "^15.15.4",
    "react-native-svg-web": "^1.0.9",
    "react-native-worklets-core": "^1.6.3",
    "tamagui": "^2.0.0-rc.41",
    "zustand": "^5.0.12"
  }
}
