generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  email     String    @unique
  password  String   
  name      String?
  role      Role      @default(USER)
  cardId    String?   @unique
  checkins  Checkin[]
}

model Checkin {
  id         Int       @id @default(autoincrement())
  createdAt  DateTime  @default(now())
  type       CheckinType @default(NONE)
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  location   String?
  method     AccessMethod
}

enum CheckinType {
  IN
  OUT
  NONE
}

enum AccessMethod {
  QR_CODE
  RFID_CARD
  MANUAL
}